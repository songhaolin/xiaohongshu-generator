{
  "schema_version": "2.0",
  "status_flow": [
    "pending",
    "generated",
    "verified",
    "published",
    "archived"
  ],
  "dedup": {
    "title_exact_match": true,
    "topic_cooldown_days": 30,
    "semantic_similarity_threshold": 0.75
  },
  "science_validation": {
    "required_sources": 3,
    "required_authority_sources": 1,
    "evidence_levels": [
      "verified",
      "conditional",
      "insufficient"
    ],
    "block_when_insufficient": true
  },
  "life_tips_short_mobile": {
    "min_chars": 180,
    "recommended_chars": 320,
    "max_chars": 380,
    "solution_count_min": 3,
    "solution_count_max": 4,
    "hashtags_min": 4,
    "hashtags_max": 6
  }
}
